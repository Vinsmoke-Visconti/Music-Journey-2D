# ============================================================
# .env - Biến môi trường | Music Journey 2D
# QUAN TRỌNG: KHÔNG đưa file này lên GitHub!
# Thêm .env vào .gitignore ngay lập tức.
# ============================================================

# --- Supabase ---
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Stripe (Phía server - Edge Function) ---
# KHÔNG đặt STRIPE_SECRET_KEY ở đây nếu chạy client-side
# Chỉ dùng trong supabase/functions/ (server-side)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# --- MoMo (Phía server - Edge Function) ---
MOMO_PARTNER_CODE=your_momo_partner_code_here
MOMO_ACCESS_KEY=your_momo_access_key_here
MOMO_SECRET_KEY=your_momo_secret_key_here

# --- App ---
VITE_APP_NAME=Music Journey 2D
VITE_APP_VERSION=0.1.0
